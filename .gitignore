# Haskell / stack
.stack-work/
*.hi
*.o

# PureScript / spago (test project)
test-project/output/
test-project/output-jl/
test-project/.spago/
test-project/node_modules/

# OS
.DS_Store

# examples
examples/*/output/
examples/*/output-jl/
examples/*/.spago/

# numexpr-edsl is split into per-backend workspaces (core/julia/node/beam), so
# the build artifacts sit one level deeper than the examples/*/ patterns reach.
examples/numexpr-edsl/*/output/
examples/numexpr-edsl/*/output-jl/
examples/numexpr-edsl/*/output-erl/
examples/numexpr-edsl/*/.spago/
examples/numexpr-edsl/*/node_modules/
examples/numexpr-edsl/beam/ebin/
erl_crash.dump

# Julia env: commit Project.toml (reproducible deps), ignore the huge,
# Julia-version-pinned Manifest (resolved by `Pkg.instantiate`)
examples/*/julia-env/Manifest.toml
examples/numexpr-edsl/julia/julia-env/Manifest.toml

# test-suite
test-suite/output/
test-suite/output-jl/
test-suite/.spago/

# generated PDFs (print workflow)
*.pdf

# python bytecode cache
__pycache__/

# Tier-2 increment-4 backend output (reproducible; committed copy lives in viz/public/)
examples/numexpr-edsl/julia/double-pendulum.json
# Tier-2 increment-5 LaTeX output (reproducible; committed copy lives in diff-viz/)
examples/numexpr-edsl/julia/derivatives.js
examples/numexpr-edsl/julia/derivatives.json
# Tier-2 increment-6 roots output (reproducible; committed copy lives in roots-viz/)
examples/numexpr-edsl/julia/roots.js
# Tier-2 increment-7 optimization output (reproducible; committed copy in opt-viz/)
examples/numexpr-edsl/julia/optimize.js
# Tier-3 petri-catlab output (reproducible; committed copy in petri-viz/)
examples/petri-catlab/petri.js
# Tier-3 catlab-patterns output (reproducible; committed copy in pattern-viz/)
examples/catlab-patterns/patterns.js

# LSP ide-server port file
.psc-ide-port
